# === LLM Providers (auto-detect: tries in order) ===
# Provider priority: Groq > NVIDIA > OpenAI > DeepSeek > Gemini > Ollama > Fallback

# === NVIDIA (Free: 1000 credits, no card needed) ===
# Get key at https://build.nvidia.com/settings/api-keys
# Model aliases: nemotron-super, deepseek-v4-pro, deepseek-v4-flash, llama-3.3, llama-3.1
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxx
# NVIDIA_NIM_URL=http://localhost:8000/v1

# === GROQ (Primary - Free tier available) ===
# Sign up at https://console.groq.com
# GROQ_API_KEY=gsk_xxxxxxxxxxxx

# === OPENAI (Alternative) ===
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# === DEEPSEEK (Cheaper than Groq) ===
# Sign up at https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx

# === GOOGLE GEMINI (Free: 60 req/min) ===
# Get key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=xxxxxxxxxxxx

# === OLLAMA (Local fallback - Mac is too heavy) ===
# Install: brew install ollama && ollama pull qwen2.5-coder
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:latest

# === Flask ===
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-jwt-secret

# === ZAP Config ===
# ZAP_PORT=8081
# ZAP_API_KEY=changeme
